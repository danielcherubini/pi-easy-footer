  "exports": {
    ".": "./src/footer/index.ts"
  },
  "files": [
    "src"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "footer",
    "statusline"
  ],
  "author": "hai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielcherubini/pi-easy-footer.git"
  },
  "homepage": "https://github.com/danielcherubini/pi-easy-footer#readme",
  "bugs": {
    "url": "https://github.com/danielcherubini/pi-easy-footer/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
